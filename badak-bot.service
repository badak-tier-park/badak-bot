[Unit]
Description=Badak Discord Bot
After=network.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/badak-bot
EnvironmentFile=/home/ubuntu/badak-bot/.env
ExecStart=/home/ubuntu/badak-bot/venv/bin/python3 bot.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
